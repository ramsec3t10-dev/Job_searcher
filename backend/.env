# EMBEDHUNT AI — environment template. Copy to backend/.env and fill real values.
# NEVER commit a filled .env. Secrets belong in a vault / CI secret store in prod.

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ── Security (generate a strong 32+ char secret in prod) ──────────────────────
SECRET_KEY=dev-secret-minimum-32-chars-change-in-prod!!
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ── CORS (comma-separated) ────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://embedhunt:embedhunt@localhost:5432/embedhunt

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Optional integrations (leave blank to disable) ────────────────────────────
OPENAI_API_KEY=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=

# ── Feature flags ─────────────────────────────────────────────────────────────
FEATURE_AUTO_APPLY=false
FEATURE_AI_MATCHING=true
FEATURE_INTERVIEW_GEN=true
