# EMBEDHUNT AI — environment template. Copy to backend/.env and fill real values.
# NEVER commit a filled .env. Secrets belong in a vault / CI secret store in prod.

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ── Security (generate a strong 32+ char secret in prod) ──────────────────────
SECRET_KEY=dev-secret-minimum-32-chars-change-in-prod!!
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ── CORS (comma-separated) ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://embedhunt:embedhunt@localhost:5432/embedhunt

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Optional integrations (leave blank to disable) ────────────────────────────
OPENAI_API_KEY=
# AI Career Mentor (Module 15) — leave blank to use the built-in rule-based mentor
ANTHROPIC_API_KEY=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=

# ── AWS Bedrock / Claude LLM layer ────────────────────────────────────────────
# When LLM_ENRICHMENT_ENABLED=true, BEDROCK_API_KEY and AWS_REGION are required
# (validated at startup). Set LLM_ENRICHMENT_ENABLED=false to run fully without
# Bedrock — every feature still works via deterministic fallbacks.
BEDROCK_API_KEY=your_bedrock_api_key_here
AWS_REGION=us-east-1
LLM_ENRICHMENT_ENABLED=true
LLM_MAX_MONTHLY_COST_USD=2.0
LLM_CACHE_TTL_SECONDS=3600
LLM_ENRICHMENT_TIMEOUT_SECONDS=10
LLM_HAIKU_MODEL=claude-haiku-4-5
LLM_SONNET_MODEL=claude-sonnet-4-6
LLM_OPUS_MODEL=claude-opus-4-8

# ── Feature flags ─────────────────────────────────────────────────────────────
FEATURE_AUTO_APPLY=false
FEATURE_AI_MATCHING=true
FEATURE_INTERVIEW_GEN=true
